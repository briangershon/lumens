{
  "name": "@briangershon/lumens-starmap-banner",
  "version": "0.1.0",
  "description": "Decorative starmap banner web component for light and dark host surfaces.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briangershon/lumens.git"
  },
  "homepage": "https://github.com/briangershon/lumens#readme",
  "bugs": {
    "url": "https://github.com/briangershon/lumens/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bundle": "./dist/lumens-starmap-banner.bundle.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "web-component",
    "custom-element",
    "starmap",
    "banner",
    "astronomy",
    "hero"
  ],
  "webComponent": {
    "tagName": "lumens-starmap-banner",
    "bundleName": "lumens-starmap-banner.bundle.js",
    "displayName": "Lumens Starmap Banner",
    "docs": {
      "summary": "A transparent animated starmap banner for editorial headers, with optional dark-mode contrast and hover selection events.",
      "slotText": "Starmap banner",
      "preview": {
        "kind": "starmap-banner",
        "eventName": "starmap-object-selected",
        "variants": [
          {
            "title": "Light host background",
            "description": "The host frame supplies the pale surface while the component keeps its foreground tuned for bright layouts.",
            "hostTheme": "light",
            "attributes": {
              "speed": "1800",
              "label-limit": "14",
              "start-time": "2026-01-15T05:00:00Z"
            }
          },
          {
            "title": "Dark host background",
            "description": "The host frame owns the dark treatment while the component switches to its higher-contrast foreground palette.",
            "hostTheme": "dark",
            "attributes": {
              "dark-mode": "",
              "speed": "1800",
              "label-limit": "14",
              "start-time": "2026-01-15T05:00:00Z"
            }
          }
        ]
      }
    }
  }
}
