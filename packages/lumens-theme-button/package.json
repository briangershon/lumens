{
  "name": "@briangershon/lumens-theme-button",
  "version": "0.1.0",
  "description": "Theme-toggle web component with light and dark modes.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bundle": "./dist/lumens-theme-button.bundle.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "web-component",
    "custom-element",
    "theme-toggle"
  ],
  "webComponent": {
    "tagName": "lumens-theme-button",
    "bundleName": "lumens-theme-button.bundle.js",
    "displayName": "Lumens Theme Button",
    "docs": {
      "summary": "A light/dark mode toggle that updates its own state and emits the selected mode.",
      "slotText": "Theme toggle",
      "initialMode": "dark",
      "preview": {
        "kind": "mode-toggle",
        "eventName": "clicked",
        "control": "mode",
        "initialMode": "dark",
        "slotText": "Theme toggle"
      }
    }
  }
}
